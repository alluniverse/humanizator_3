# Application
APP_NAME=humanizator
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://humanizator:humanizator@db:5432/humanizator
DATABASE_URL_SYNC=postgresql://humanizator:humanizator@db:5432/humanizator

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# Observability
LOG_LEVEL=INFO
ENABLE_PROMETHEUS=true
